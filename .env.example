OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# If a third-party provider uses a different environment variable for its key,
# set OPENAI_API_KEY_ENV to that variable name instead of copying the key.
# Example: OPENAI_API_KEY_ENV=THIRD_PARTY_API_KEY
OPENAI_API_KEY_ENV=

# Most OpenAI-compatible providers use Authorization: Bearer <key>.
OPENAI_AUTH_HEADER=Authorization
OPENAI_AUTH_SCHEME=Bearer

# Optional JSON for provider-specific headers.
# Example: OPENAI_EXTRA_HEADERS={"HTTP-Referer":"http://localhost"}
OPENAI_EXTRA_HEADERS=

# Keep this as gpt-image-2 if your account has access.
# If the API says the model is unavailable, try gpt-image-1.5 or gpt-image-1.
OPENAI_IMAGE_MODEL=gpt-image-2

# Common examples: 1024x1024, 1024x1536, 1536x1024.
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=auto
IMAGE_BACKGROUND=auto
IMAGE_OUTPUT_FORMAT=png

# Image editing defaults.
OPENAI_IMAGE_EDIT_PATH=/images/edits

# Chat completions probe.
# OPENAI_CHAT_COMPLETIONS_PATH=/chat/completions
