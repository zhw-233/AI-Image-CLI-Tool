IMAGE_API_KEY=your-api-key
IMAGE_API_BASE_URL=https://your-image-api.example.com/v1

# If a provider uses a different environment variable for its key,
# set IMAGE_API_KEY_ENV to that variable name instead of copying the key.
# Example: IMAGE_API_KEY_ENV=THIRD_PARTY_API_KEY
IMAGE_API_KEY_ENV=

# Most image API providers use Authorization: Bearer <key>.
IMAGE_API_AUTH_HEADER=Authorization
IMAGE_API_AUTH_SCHEME=Bearer

# Optional JSON for provider-specific headers.
# Example: IMAGE_API_EXTRA_HEADERS={"HTTP-Referer":"http://localhost"}
IMAGE_API_EXTRA_HEADERS=

# Set this to the image model name required by your provider.
IMAGE_API_MODEL=your-image-model

# Common examples: 1024x1024, 1024x1536, 1536x1024.
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=auto
IMAGE_BACKGROUND=auto
IMAGE_OUTPUT_FORMAT=png

# Image editing defaults.
IMAGE_API_EDIT_PATH=/images/edits
