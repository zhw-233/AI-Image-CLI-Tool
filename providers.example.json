{
  "providers": {
    "default": {
      "name": "Default image API provider",
      "baseUrl": "https://your-image-api.example.com/v1",
      "model": "your-image-model",
      "apiKeyEnv": "IMAGE_API_KEY",
      "authHeader": "Authorization",
      "authScheme": "Bearer"
    },
    "third-party": {
      "name": "Another image API provider",
      "baseUrl": "https://another-image-api.example.com/v1",
      "model": "another-image-model",
      "apiKeyEnv": "THIRD_PARTY_API_KEY",
      "authHeader": "Authorization",
      "authScheme": "Bearer",
      "extraHeaders": {
        "X-Provider": "example"
      }
    }
  }
}
